{
  "name": "jspf-md-demo",
  "version": "1.7.1",
  "description": "FIX 4.4 market data demo using quick fix data dictionary",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1",
    "circular": "madge --circular --extensions js dist && madge --circular --extensions ts src",
    "generate": "cd node_modules/jspurefix/dist && node jsfix-cmd \"--dict=../../data/FIX44-MD.xml\" \"--compile\" \"--output=../../src/types/FIX44\"",
    "generate5": "cd node_modules/jspurefix/dist && node jsfix-cmd \"--dict=../../data/FIX50SP2.xml\" \"--compile\" \"--output=../../src/types/FIX50SP2\"",
    "replay": "cd node_modules/jspurefix/dist && node jsfix-cmd \"--dict=../../data/FIX44-MD.xml\" \"--fix=../../data/example/fix.txt\" \"--objects\" --delimiter=\"|\"",
    "tokens": "cd node_modules/jspurefix/dist && node jsfix-cmd \"--dict=../../data/FIX44-MD.xml\" \"--fix=../../data/example/fix.txt\" \"--tokens\" --delimiter=\"|\"",
    "md-app": "cd dist/v44/app && node app --port 3000 --server ../../data/session/v44/test-acceptor.json",
    "md5-app": "cd dist/v50sp2/app && node app --port 3000 --server ../../data/session/v50sp2/test-acceptor.json",
    "help": "cd dist/v44/app && node app --help"
  },
  "keywords": [
    "quickfix",
    "fix",
    "jspurefix"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.2",
    "jspurefix": "^5.2.0",
    "reflect-metadata": "^0.2.2"
  },
  "overrides": {
    "typescript": "$typescript"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/sax": "^1.2.7",
    "eslint": "^9.39.4",
    "eslint-config-love": "^151.0.0",
    "madge": "^8.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
